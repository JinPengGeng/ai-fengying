# Git Attributes - 敏感信息处理配置
# 自动处理行尾和敏感信息

# 自动处理行尾符
* text=auto

# 标记为二进制文件（不进行diff和merge）
*.pem binary
*.key binary
*.p12 binary
*.pfx binary
*.der binary
*.cer binary
*.crt binary

# 敏感信息文件 - 使用过滤器
.env filter=hide-secrets
.env.* filter=hide-secrets
*.secret filter=hide-secrets
secrets/* filter=hide-secrets
credentials.json filter=hide-secrets
config.local.* filter=hide-secrets

# 确保某些文件始终使用LF行尾
*.sh text eol=lf
*.bash text eol=lf
